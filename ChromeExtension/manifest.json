{
  "name": "INHACK Auth Popup",
  "description": "로그인/회원가입 및 Dreamhack 로그인 버튼",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "tabs",
    "cookies",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "https://127.0.0.1:8080/*",
    "http://ddyoru.duckdns.org/*",
    "https://ddyoru.duckdns.org/*",
    "https://dreamhack.io/*",
    "https://*.dreamhack.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "/images/inhack-logo-16.png",
      "32": "/images/inhack-logo-32.png",
      "64": "/images/inhack-logo-64.png",
      "128": "/images/inhack-logo-128.png"
    }
  },
  "icons": {
    "16": "/images/inhack-logo-16.png",
    "32": "/images/inhack-logo-32.png",
    "64": "/images/inhack-logo-64.png",
    "128": "/images/inhack-logo-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8080/*",
        "https://localhost:8080/*",
        "http://127.0.0.1:8080/*",
        "https://127.0.0.1:8080/*",
        "http://ddyoru.duckdns.org/*",
        "https://ddyoru.duckdns.org/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}