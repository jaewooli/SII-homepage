# Dreamhack Account Settings (Required for validation/syncing solves)
DREAMHACKEMAIL=your-dreamhack-email@example.com
DREAMHACKPASSWORD=your-dreamhack-password

# Server Config
PORT=8080
SESSION_SECRET=your_secure_session_secret_key_here
SESSION_NAME=sid

# Application Base Path for subpath routing (e.g. /homepage)
BASE_PATH=/homepage

# Super Admin / Developer Default Credentials
ADMIN_USERNAME=developer
ADMIN_PASSWORD=your_initial_admin_password
